APP_NAME="Моделизм"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dev-cloude.modelizmclub.ru

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

# OpenAPI-документация (Scramble) — открыть на дев-сервере
API_VERSION=v1
SCRAMBLE_ENABLED=true

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# daily — общий ротационный лог; errors — отдельный дневной файл только с ошибками
LOG_STACK=daily,errors
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14
LOG_ERROR_DAYS=90

# PostgreSQL — боевая БД (VPS Beget, данные в РФ)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=modelizm
DB_USERNAME=modelizm
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.modelizmclub.ru

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@modelizmclub.ru"
MAIL_FROM_NAME="${APP_NAME}"

# S3 (Selectel) — российский S3-совместимый провайдер
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-1
AWS_BUCKET=
AWS_ENDPOINT=https://s3.ru-1.storage.selcloud.ru
AWS_USE_PATH_STYLE_ENDPOINT=true
# Публичный URL бакета (если медиа отдаётся напрямую из S3)
AWS_URL=

# Медиа и загрузки
# Диск хранения медиа: public (локально) или s3 (Selectel)
MEDIA_DISK=public
# Выделенный поддомен для фото/медиа (CDN-домен). Пусто — отдаём с APP_URL/storage
MEDIA_URL=https://img.modelizmclub.ru
# Обработка изображений
IMAGE_DRIVER=gd
IMAGE_FORMAT=webp
IMAGE_QUALITY=82
IMAGE_OPTIMIZE=true
# Лимиты загрузок (в КБ)
UPLOAD_MAX_FILE_KB=204800
UPLOAD_AVATAR_MAX_KB=5120
UPLOAD_PHOTO_MAX_KB=15360
UPLOAD_ATTACHMENT_MAX_KB=20480
UPLOAD_AD_MAX_PHOTOS=10

# Лимиты запросов (rate limiting), запросов в минуту
RATE_LIMIT_API=120
RATE_LIMIT_GUEST=40
RATE_LIMIT_UPLOADS=30

# Laravel Reverb (WebSockets)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="dev-cloude.modelizmclub.ru"
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# OAuth: VK ID / Яндекс ID
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI="${APP_URL}/api/v1/auth/social/vkontakte/callback"
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI="${APP_URL}/api/v1/auth/social/yandex/callback"

# Платёжные провайдеры (эквайринг ВТБ / ЮKassa) — ключи хранятся зашифрованно
VTB_TERMINAL_KEY=
VTB_SECRET_KEY=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

VITE_APP_NAME="${APP_NAME}"
